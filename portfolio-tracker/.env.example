# Zkopírujte do .env a vyplňte

# Náhodný klíč pro šifrování session — vygenerujte:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sem-vlozte-nahodny-retezec

# Heslo pro přihlášení do aplikace
APP_PASSWORD=vase-heslo

# Service account z Firebase (celý JSON na jednom řádku)
# Stáhnout: Firebase Console → Project Settings → Service accounts → Generate new private key
# Pak: cat serviceAccountKey.json | python -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}
